# Samity API - copy to .env and fill in secrets. NEVER commit .env.
# MongoDB MUST be a replica set. Atlas clusters already are replica sets.
# No Redis: locks/OTP/blacklist/rate-limit run on Mongo TTL collections.

# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/samity?retryWrites=true&w=majority

# JWT
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS
CORS_ORIGIN=*

# Object Storage (S3-compatible: AWS S3, Cloudflare R2, DigitalOcean Spaces, MinIO)
# Set STORAGE_ENABLED=false during development; uploads become no-ops.
STORAGE_ENABLED=false
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=samity-uploads
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_URL_BASE=

# Firebase Cloud Messaging
# Firebase Console > Project Settings > Service accounts > Generate new private key
# Encode to base64 without line breaks:
# Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes('service-account.json'))
FCM_SERVICE_ACCOUNT_JSON=

# SMS Gateway (SylSMS OTP delivery)
# SylSMS API: http://web.sylsms.xyz/api/smsapi?api_key=...&type=text&number=...&senderid=...&message=...
SMS_ENABLED=false
SMS_BASE_URL=http://web.sylsms.xyz/api
SMS_SEND_PATH=smsapi
SMS_API_KEY=
SMS_SENDER_ID=SAMITY
SMS_METHOD=GET
SMS_BODY_FORMAT=query
SMS_TYPE=text
SMS_AUTH_PARAM=api_key
SMS_SENDER_PARAM=senderid
SMS_TO_PARAM=number
SMS_MESSAGE_PARAM=message
SMS_SUCCESS_REGEX=^202
