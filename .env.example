# Samity API — copy to .env and fill. NEVER commit .env.
PORT=4000
NODE_ENV=development

# MongoDB — MUST be a replica set (Atlas clusters already are).
# Also hosts TTL/lock collections (otps, tokenBlacklist, refreshTokens, locks, rateLimits) — no Redis.
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/samity?retryWrites=true&w=majority

# JWT — generate strong random secrets:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS (comma-separated origins; * for dev)
CORS_ORIGIN=*

# SMS gateway (OTP). SylSMS single-SMS API:
# http://web.sylsms.xyz/api/smsapi?api_key=...&type=text&number=...&senderid=DUARE&message=...
SMS_ENABLED=false
SMS_BASE_URL=http://web.sylsms.xyz/api
SMS_SEND_PATH=smsapi
# SMS_API_KEY=
# SMS_SENDER_ID=DUARE
SMS_METHOD=GET
SMS_BODY_FORMAT=query
SMS_TYPE=text
SMS_AUTH_PARAM=api_key
SMS_SENDER_PARAM=senderid
SMS_TO_PARAM=number
SMS_MESSAGE_PARAM=message
SMS_SUCCESS_REGEX=^202

# --- below are Phase 09/14, optional for now ---
# FCM_PROJECT_ID=
# STORAGE_ENDPOINT=
# STORAGE_BUCKET=
# STORAGE_KEY=
# STORAGE_SECRET=
# WHATSAPP_API_TOKEN=
