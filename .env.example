# Samity API - copy to .env and fill in secrets. NEVER commit .env.
# MongoDB MUST be a replica set. Atlas clusters already are replica sets.
# No Redis: locks/OTP/blacklist/rate-limit run on Mongo TTL collections.

# Server
PORT=4000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/samity?retryWrites=true&w=majority

# JWT
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS
CORS_ORIGIN=*

# File Storage
# STORAGE_ENABLED=false during dev → uploads become no-ops (key returned, nothing written).
# STORAGE_DRIVER=local → store on THIS server's disk (Hostinger VPS). 's3' → S3-compatible bucket.
STORAGE_ENABLED=false
STORAGE_DRIVER=local

# --- local driver (STORAGE_DRIVER=local) ---
# Disk path for uploads. In Docker, mount a host volume here so files survive rebuilds.
UPLOAD_DIR=uploads
# Public base for viewing files. Points at the app's own /files mount:
STORAGE_URL_BASE=https://samity-server.duare.net/files

# --- s3 driver (STORAGE_DRIVER=s3) --- leave blank when using local
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Firebase Cloud Messaging
# Firebase Console > Project Settings > Service accounts > Generate new private key
# Encode to base64 without line breaks:
# Windows PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes('service-account.json'))
FCM_SERVICE_ACCOUNT_JSON=

# SMS Gateway (SylSMS OTP delivery)
# SylSMS API: http://web.sylsms.xyz/api/smsapi?api_key=...&type=text&number=...&senderid=...&message=...
SMS_ENABLED=false
SMS_BASE_URL=http://web.sylsms.xyz/api
SMS_SEND_PATH=smsapi
SMS_API_KEY=
SMS_SENDER_ID=SAMITY
SMS_METHOD=GET
SMS_BODY_FORMAT=query
SMS_TYPE=text
SMS_AUTH_PARAM=api_key
SMS_SENDER_PARAM=senderid
SMS_TO_PARAM=number
SMS_MESSAGE_PARAM=message
SMS_SUCCESS_REGEX=^202

# Optional Google Play review access
# Configure a dedicated review-only phone/password in production so reviewers can log in
# without waiting for SMS. The fixed OTP is only accepted for PLAY_REVIEW_PHONE.
PLAY_REVIEW_PHONE=
PLAY_REVIEW_PASSWORD=
PLAY_REVIEW_OTP=123456
PLAY_REVIEW_NAME=Play Store Reviewer
