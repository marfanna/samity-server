# Samity API — copy to .env and fill. NEVER commit .env.
PORT=4000
NODE_ENV=development

# MongoDB — MUST be a replica set (Atlas clusters already are).
# Also hosts TTL/lock collections (otps, tokenBlacklist, refreshTokens, locks, rateLimits) — no Redis.
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/samity?retryWrites=true&w=majority

# JWT — generate strong random secrets:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS (comma-separated origins; * for dev)
CORS_ORIGIN=*

# --- below are Phase 09/14, optional for now ---
# SMS_API_KEY=
# FCM_PROJECT_ID=
# STORAGE_ENDPOINT=
# STORAGE_BUCKET=
# STORAGE_KEY=
# STORAGE_SECRET=
# WHATSAPP_API_TOKEN=
